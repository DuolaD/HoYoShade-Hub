<?xml version="1.0" encoding="utf-8" ?>
<sf:PageBase x:Class="HoYoShadeHub.Features.Setting.GeneralSetting"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:lang="using:HoYoShadeHub.Language"
             xmlns:local="using:HoYoShadeHub.Features.Setting"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
              xmlns:models="using:HoYoShadeHub.Models"
             xmlns:sf="using:HoYoShadeHub.Frameworks"
             xmlns:sfv="using:HoYoShadeHub.Features.ViewHost"
             x:DefaultBindMode="OneWay"
             mc:Ignorable="d">

    <ScrollViewer>
        <StackPanel Padding="0,0,24,0" Margin="0,0,0,20">


            <!--  语言  -->
            <TextBlock FontSize="20" Text="{x:Bind lang:Lang.SettingPage_Language}" />
            <ComboBox Name="ComboBox_Language"
                      Height="36"
                      MinWidth="260"
                      Margin="0,12,0,0"
                      Padding="18.5,0,0,0"
                      BorderThickness="0"
                      CornerRadius="8,18,18,8"
                      SelectionChanged="ComboBox_Language_SelectionChanged" />

            <!--  帮助翻译  -->
            <TextBlock Margin="0,12,0,0" HorizontalAlignment="Left">
                <Hyperlink NavigateUri="https://github.com/Scighost/HoYoShadeHub/blob/main/docs/Localization.md" UnderlineStyle="None">
                    <Run Text="{x:Bind lang:Lang.AppearanceSettingPage_HelpUsTranslateHoYoShadeHub}" />
                </Hyperlink>
            </TextBlock>


            <!--  关闭窗口选项  -->
            <TextBlock Margin="0,20,0,0"
                       FontSize="20"
                       Text="{x:Bind lang:Lang.ExperienceSettingPage_CloseWindowOption}" />
            <StackPanel Margin="0,12,0,0"
                        Orientation="Horizontal"
                        Spacing="24">
                <RadioButton Name="RadioButton_CloseWindowOption_Hide"
                             Checked="RadioButton_CloseWindowOption_Checked"
                             Content="{x:Bind lang:Lang.ExperienceSettingPage_MinimizeToSystemTray}"
                             GroupName="CloseWindowOption"
                             Tag="{x:Bind sfv:MainWindowCloseOption.Hide}" />
                <RadioButton Name="RadioButton_CloseWindowOption_Exit"
                             Checked="RadioButton_CloseWindowOption_Checked"
                             Content="{x:Bind lang:Lang.ExperienceSettingPage_ExitCompletely}"
                             GroupName="CloseWindowOption"
                             Tag="{x:Bind sfv:MainWindowCloseOption.Exit}" />
            </StackPanel>


            <TextBlock Margin="0,20,0,0"
                       FontSize="20"
                       Text="{x:Bind lang:Lang.SettingPage_MainInterface}" />


            <!--  禁用自动播放视频背景  -->
            <ToggleSwitch Margin="0,20,0,0"
                          IsOn="{x:Bind DefaultDisableVideoBackgroundPlayback, Mode=TwoWay}"
                          OffContent="{x:Bind lang:Lang.SettingPage_DefaultDisableVideoBackgroundPlayback}"
                          OnContent="{x:Bind lang:Lang.SettingPage_DefaultDisableVideoBackgroundPlayback}" />

            <TextBlock Margin="0,20,0,0"
                       FontSize="20"
                       Text="{x:Bind lang:Lang.SettingPage_Network}" />

            <StackPanel Height="32"
                        Margin="0,12,0,0"
                        Orientation="Horizontal"
                        Spacing="12">
                <FontIcon Margin="0,0,-4,0"
                          FontSize="16"
                          Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                          Glyph="&#xE701;"
                          IsTextScaleFactorEnabled="False" />
                <TextBlock VerticalAlignment="Center"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                           IsTextScaleFactorEnabled="False"
                           Text="{x:Bind lang:Lang.WelcomeView_NetworkStatus}" />
                <TextBlock VerticalAlignment="Center"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                           IsTextScaleFactorEnabled="False"
                           Text="{x:Bind NetworkDelay}" />
                <TextBlock VerticalAlignment="Center"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                           IsTextScaleFactorEnabled="False"
                           Text="{x:Bind NetworkSpeed}" />
                <Button Padding="4"
                        VerticalAlignment="Center"
                        BorderThickness="0"
                        Click="Button_RefreshNetworkStatus_Click"
                        Style="{ThemeResource DateTimePickerFlyoutButtonStyle}">
                    <Grid>
                        <FontIcon FontSize="14"
                                  Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"
                                  Glyph="&#xE72C;"
                                  IsTextScaleFactorEnabled="False"
                                  Visibility="{x:Bind IsRefreshingNetworkStatus, Converter={StaticResource BoolToVisibilityReversedConverter}}" />
                        <ProgressRing Width="16"
                                      Height="16"
                                      IsActive="{x:Bind IsRefreshingNetworkStatus}" />
                    </Grid>
                </Button>
            </StackPanel>

            <ToggleSwitch Margin="0,12,0,0"
                          IsOn="{x:Bind EnableDoh, Mode=TwoWay}"
                          OffContent="DoH(DNS over HTTPS)"
                          OnContent="DoH(DNS over HTTPS)" />

            <StackPanel Margin="0,8,0,0" Visibility="{x:Bind EnableDoh, Converter={StaticResource BoolToVisibilityConverter}}">
                <TextBlock Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                           Text="选择DNS提供商：" />

                <ComboBox MinWidth="300"
                          Margin="0,8,0,0"
                          HorizontalAlignment="Left"
                          ItemsSource="{x:Bind DohProviders}"
                          SelectedItem="{x:Bind SelectedDohProvider, Mode=TwoWay}">
                    <ComboBox.ItemTemplate>
                        <DataTemplate x:DataType="models:DownloadServerItem">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Margin="0,0,16,0" VerticalAlignment="Center" Text="{x:Bind Name}" />
                                <Border Grid.Column="1"
                                        Padding="6,2"
                                        VerticalAlignment="Center"
                                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                        BorderThickness="1"
                                        CornerRadius="4"
                                        Visibility="{x:Bind LatencyText, Mode=OneWay, Converter={StaticResource WhiteSpaceStringToVisibilityConverter}}">
                                    <TextBlock FontSize="12"
                                               VerticalAlignment="Center"
                                               Foreground="{x:Bind LatencyColor, Mode=OneWay}"
                                               Text="{x:Bind LatencyText, Mode=OneWay}"
                                               UseLayoutRounding="True" />
                                </Border>
                            </Grid>
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>

                <TextBlock Margin="0,8,0,0"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                           Text="该功能可帮助 HoYoShade Hub 绕过部分网络环境下基于传统DNS劫持/污染/抢答的封锁措施，从而解决部分连接性问题。"
                           TextWrapping="Wrap" />
                <TextBlock Margin="0,8,0,0"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                           Text="{x:Bind DohDescriptionText, Mode=OneWay}"
                           TextWrapping="Wrap" />
                <TextBlock Margin="0,8,0,0"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                           Text="{x:Bind DohDescriptionText2, Mode=OneWay}"
                           TextWrapping="Wrap" />
                <TextBlock Margin="0,8,0,0"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                           Text="在此设备/在此网络中运行的VPN/代理程序可能会影响此处的网络状态/DNS提供商状态显示。"
                           TextWrapping="Wrap" />
                <TextBlock Margin="0,8,0,0"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                           Text="如果发生连接性问题，请先尝试更换其它DNS提供商，或尝试开启/关闭DoH。"
                           TextWrapping="Wrap" />
            </StackPanel>


            <MenuFlyoutSeparator Margin="0,20,0,0" />

            <!--  透明/动画效果  -->
            <TextBlock Margin="0,20,0,0"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                       Text="{x:Bind lang:Lang.SettingPage_ForABetterExperiencePleaseEnableTheFollowingFeaturesInSystemSettings}"
                       TextWrapping="Wrap" />
            <TextBlock Margin="0,12,0,0" HorizontalAlignment="Left">
                <Hyperlink Click="Hyperlink_VisualEffects_Click"
                           NavigateUri="ms-settings:easeofaccess-visualeffects"
                           UnderlineStyle="None">
                    <Run Text="{x:Bind lang:Lang.AppearanceSettingPage_TransparencyEffects}" />
                </Hyperlink>
                <Run Text="" />
                <Run Text="" />
                <Hyperlink Click="Hyperlink_VisualEffects_Click"
                           NavigateUri="ms-settings:easeofaccess-visualeffects"
                           UnderlineStyle="None">
                    <Run Text="{x:Bind lang:Lang.AppearanceSettingPage_AnimationEffects}" />
                </Hyperlink>
            </TextBlock>

        </StackPanel>
    </ScrollViewer>

</sf:PageBase>
