<?xml version="1.0" encoding="utf-8" ?>
<ContentDialog x:Class="HoYoShadeHub.Features.Setting.NetworkSettingDialog"
               xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
               xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
               xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
               xmlns:lang="using:HoYoShadeHub.Language"
               xmlns:models="using:HoYoShadeHub.Models"
               xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
               x:DefaultBindMode="OneWay"
               Title="{x:Bind lang:Lang.SettingPage_Network}"
               PrimaryButtonText="{x:Bind lang:Lang.Common_Confirm}"
               DefaultButton="Primary"
               PrimaryButtonClick="ContentDialog_PrimaryButtonClick"
               Closed="ContentDialog_Closed"
               Style="{ThemeResource DefaultContentDialogStyle}"
               mc:Ignorable="d">

    <ContentDialog.Resources>
        <x:Double x:Key="ContentDialogMinWidth">520</x:Double>
        <x:Double x:Key="ContentDialogMaxWidth">600</x:Double>
    </ContentDialog.Resources>

    <Grid Width="520" RowSpacing="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <StackPanel Spacing="16">
            <!--  网络状态  -->
            <StackPanel Height="32"
                        Orientation="Horizontal"
                        Spacing="12">
                <FontIcon Margin="0,0,-4,0"
                          FontSize="16"
                          Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                          Glyph="&#xE701;"
                          IsTextScaleFactorEnabled="False" />
                <TextBlock VerticalAlignment="Center"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                           IsTextScaleFactorEnabled="False"
                           Text="{x:Bind lang:Lang.WelcomeView_NetworkStatus}" />
                <TextBlock VerticalAlignment="Center"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                           IsTextScaleFactorEnabled="False"
                           Text="{x:Bind NetworkDelay}" />
                <TextBlock VerticalAlignment="Center"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                           IsTextScaleFactorEnabled="False"
                           Text="{x:Bind NetworkSpeed}" />
                <Button Padding="4"
                        VerticalAlignment="Center"
                        BorderThickness="0"
                        Click="Button_RefreshNetworkStatus_Click"
                        Style="{ThemeResource DateTimePickerFlyoutButtonStyle}">
                    <Grid>
                        <FontIcon FontSize="14"
                                  Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"
                                  Glyph="&#xE72C;"
                                  IsTextScaleFactorEnabled="False"
                                  Visibility="{x:Bind IsRefreshingNetworkStatus, Converter={StaticResource BoolToVisibilityReversedConverter}}" />
                        <ProgressRing Width="16"
                                      Height="16"
                                      IsActive="{x:Bind IsRefreshingNetworkStatus}" />
                    </Grid>
                </Button>
            </StackPanel>

            <!--  系统代理  -->
            <StackPanel Height="32"
                        Orientation="Horizontal"
                        Spacing="12">
                <FontIcon Margin="0,0,-4,0"
                          FontSize="16"
                          Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                          Glyph="&#xE705;"
                          IsTextScaleFactorEnabled="False" />
                <TextBlock VerticalAlignment="Center"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                           IsTextScaleFactorEnabled="False"
                           Text="{x:Bind SystemProxyTitleText, Mode=OneWay}" />
                <TextBlock VerticalAlignment="Center"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                           IsTextScaleFactorEnabled="False"
                           Text="{x:Bind SystemProxyStatusText, Mode=OneWay}" />
            </StackPanel>

            <ToggleSwitch IsOn="{x:Bind EnableDoh, Mode=TwoWay}"
                          OffContent="{x:Bind DohSwitchText, Mode=OneWay}"
                          OnContent="{x:Bind DohSwitchText, Mode=OneWay}" />

            <TextBlock Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                       Text="{x:Bind DohDisabledDescriptionText, Mode=OneWay}"
                       TextWrapping="Wrap"
                       Visibility="{x:Bind EnableDoh, Converter={StaticResource BoolToVisibilityReversedConverter}}" />

            <StackPanel Visibility="{x:Bind EnableDoh, Converter={StaticResource BoolToVisibilityConverter}}">
                <TextBlock Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                           Text="{x:Bind DohProviderText, Mode=OneWay}" />

                <ComboBox MinWidth="300"
                          Margin="0,8,0,0"
                          HorizontalAlignment="Left"
                          ItemsSource="{x:Bind DohProviders}"
                          SelectedItem="{x:Bind SelectedDohProvider, Mode=TwoWay}">
                    <ComboBox.ItemTemplate>
                        <DataTemplate x:DataType="models:DownloadServerItem">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Margin="0,0,16,0" VerticalAlignment="Center" Text="{x:Bind Name}" />
                                <Border Grid.Column="1"
                                        Padding="6,2"
                                        VerticalAlignment="Center"
                                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                        BorderThickness="1"
                                        CornerRadius="4"
                                        Visibility="{x:Bind LatencyText, Mode=OneWay, Converter={StaticResource WhiteSpaceStringToVisibilityConverter}}">
                                    <TextBlock FontSize="12"
                                               VerticalAlignment="Center"
                                               Foreground="{x:Bind LatencyColor, Mode=OneWay}"
                                               Text="{x:Bind LatencyText, Mode=OneWay}"
                                               UseLayoutRounding="True" />
                                </Border>
                            </Grid>
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>

                <TextBlock Margin="0,8,0,0"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                           Text="{x:Bind DohDescriptionText, Mode=OneWay}"
                           TextWrapping="Wrap" />
            </StackPanel>

            <ToggleSwitch Margin="0,8,0,0"
                          IsOn="{x:Bind EnableEch, Mode=TwoWay}"
                          IsEnabled="{x:Bind EnableDoh, Mode=OneWay}"
                          OffContent="{x:Bind EchSwitchText, Mode=OneWay}"
                          OnContent="{x:Bind EchSwitchText, Mode=OneWay}" />

            <TextBlock Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                       Text="{x:Bind EchDescriptionText, Mode=OneWay}"
                       TextWrapping="Wrap" />

            <TextBlock Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                       Text="{x:Bind EchRequirementNoticeText, Mode=OneWay}"
                       TextWrapping="Wrap"
                       Visibility="{x:Bind EnableDoh, Converter={StaticResource BoolToVisibilityReversedConverter}}" />

            <TextBlock Margin="0,8,0,0"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                       Text="{x:Bind NetworkDescriptionText, Mode=OneWay}"
                       TextWrapping="Wrap" />
        </StackPanel>
    </Grid>
</ContentDialog>
